# ===========================================
# EvoFaceFlow Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ----------------
# Server Settings
# ----------------
NODE_ENV=development
PORT=5000

# ----------------
# MongoDB
# ----------------
# Development (local docker-compose)
MONGO_URI=mongodb://root:devpassword123@mongo:27017/evofaceflow?authSource=admin

# Production format:
# MONGO_URI=mongodb://evoface_user:<PASSWORD>@mongo:27017/evofaceflow?authSource=admin

# ----------------
# JWT Authentication
# ----------------
# REQUIRED: Generate with: openssl rand -hex 32
JWT_SECRET=

# ----------------
# AWS Settings
# ----------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=evofaceflow-uploads

# ----------------
# Redis
# ----------------
REDIS_URL=redis://redis:6379
# For production with password:
# REDIS_URL=redis://:yourpassword@redis:6379

# ----------------
# Admin Access
# ----------------
# Required for /api/admin routes
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# ----------------
# CORS Settings
# ----------------
# Comma-separated list of allowed origins
# Example: https://evofaceflow.com,exp://192.168.1.100:8081
ALLOWED_ORIGINS=http://localhost:3000,exp://localhost:8081

# ----------------
# Email (Future - AWS SES)
# ----------------
# SES_FROM_EMAIL=noreply@evofaceflow.com
# SES_REGION=us-east-1
